{
	"name": "nuxt-smartness-ui",
	"type": "module",
	"version": "1.10.4",
	"private": true,
	"packageManager": "pnpm@10.32.1",
	"description": "Nuxt Smartness UI",
	"author": "Smartness",
	"exports": {
		".": {
			"import": "./nuxt.config.ts"
		},
		"./eslint": {
			"types": "./eslint.preset.d.ts",
			"import": "./eslint.preset.mjs"
		},
		"./types": {
			"types": "./app/types/index.ts",
			"import": "./app/types/index.ts"
		},
		"./*": "./*"
	},
	"main": "./nuxt.config.ts",
	"types": "./app/types/index.ts",
	"scripts": {
		"dev": "pnpm generate:colors && nuxi dev",
		"generate:colors": "jiti scripts/generate-colors.ts",
		"play": "pnpm generate:colors && nuxi dev .playground",
		"dev:playground": "pnpm generate:colors && nuxi dev .playground",
		"prepare:playground": "pnpm generate:colors && nuxt prepare .playground",
		"build": "pnpm generate:colors && nuxt build .playground",
		"generate": "pnpm generate:colors && nuxt generate .playground",
		"preview": "nuxt preview .playground",
		"lint": "nuxt prepare && eslint ./app",
		"lint:fix": "nuxt prepare && eslint ./app --fix",
		"release": "bash ./scripts/release.sh"
	},
	"peerDependencies": {
		"maplibre-gl": "^5.21.0"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.8",
		"@internationalized/date": "^3.12.2",
		"@nuxt/fonts": "^0.14.0",
		"@nuxt/ui": "^4.10.0",
		"@nuxtjs/mdc": "^0.22.1",
		"@tailwindcss/vite": "^4.3.2",
		"@vuepic/vue-datepicker": "^14.0.0",
		"@vueuse/core": "^14.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"date-fns": "^4.4.0",
		"echarts": "^6.1.0",
		"libphonenumber-js": "^1.13.8",
		"maplibre-gl": "^5.24.0",
		"maska": "^3.2.0",
		"reka-ui": "^2.10.1",
		"tailwindcss": "^4.3.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^9.1.0",
		"@nuxt/eslint": "^1.16.0",
		"bumpp": "^11.1.0",
		"changelogen": "^0.6.2",
		"eslint": "^10.6.0",
		"nuxt": "^4.4.8",
		"typescript": "^6.0.3"
	}
}
